@namespace eShopLegacyWebForms.Components.Pages.Catalog.Details

@page "/Catalog/Details/{id:int}"

@using eShopLegacyWebForms.Models
@using eShopLegacyWebForms.Services
@using Microsoft.Extensions.Logging

@inject ICatalogService CatalogService
@inject ILogger<Details> Logger

<h2 class="esh-body-title">Details</h2>

<div class="container">
    <div class="row">
        @if (product != null)
        {
            <img class="col-md-6 esh-picture" src="@("/Pics/" + product.PictureFileName)" alt="@product.Name" />
            <dl class="col-md-6 dl-horizontal">
                <dt>Name
                </dt>

                <dd>
                    <span>@product.Name</span>
                </dd>

                <dt>Description
                </dt>

                <dd>
                    <span>@product.Description</span>
                </dd>

                <dt>Brand
                </dt>

                <dd>
                    <span>@product.CatalogBrand.Brand</span>
                </dd>

                <dt>Type
                </dt>

                <dd>
                    <span>@product.CatalogType.Type</span>
                </dd>

                <dt>Price
                </dt>

                <dd>
                    <span class="esh-price">@product.Price</span>
                </dd>

                <dt>Picture name
                </dt>

                <dd>
                    <span>@product.PictureFileName</span>
                </dd>

                <dt>Stock
                </dt>

                <dd>
                    <span>@product.AvailableStock</span>
                </dd>

                <dt>Restock
                </dt>

                <dd>
                    <span>@product.RestockThreshold</span>
                </dd>

                <dt>Max stock
                </dt>

                <dd>
                    <span>@product.MaxStockThreshold</span>
                </dd>

            </dl>
        }
    </div>

    <div class="form-actions no-color esh-link-list">
        <NavLink href="@($"/Catalog/Edit/{Id}")" class="esh-link-item">Edit
        </NavLink>
        |
        <NavLink href="/Catalog" class="esh-link-item">Back to list
        </NavLink>
    </div>

</div>

@code {
    [Parameter]
    public int Id { get; set; }

    protected CatalogItem product;

    protected override void OnParametersSet()
    {
        Logger.LogInformation($"Now loading... /Catalog/Details.aspx?id={Id}");
        product = CatalogService.FindCatalogItem(Id);
    }
}