@namespace eShopLegacyWebForms.Components.Pages.Catalog.Edit

@page "/Catalog/Edit/{id:int}"
@rendermode InteractiveServer

@using eShopLegacyWebForms.Models
@using eShopLegacyWebForms.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Logging

@inject ICatalogService CatalogService
@inject NavigationManager NavigationManager
@inject ILogger<Edit> Logger

<h2 class="esh-body-title">Edit</h2>

<div class="container">
    <div class="row">
        <img src="@("/Pics/" + product.PictureFileName)" class="col-md-6 esh-picture" alt="Product picture" />
        <div class="col-md-6 form-horizontal">

            <EditForm Model="@catalogItem" OnValidSubmit="Save_Click" FormName="EditCatalogItem">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label class="control-label col-md-4">Name</label>
                    <div class="col-md-8">
                        <InputText id="Name" class="form-control" @bind-Value="catalogItem.Name" />
                        <ValidationMessage For="@(() => catalogItem.Name)" class="field-validation-valid text-danger" />
                        @if (string.IsNullOrWhiteSpace(catalogItem.Name) && hasSubmitted)
                        {
                            <span class="field-validation-valid text-danger">The Name field is required.</span>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-4">Description</label>
                    <div class="col-md-8">
                        <InputText id="Description" class="form-control" @bind-Value="catalogItem.Description" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-4">Brand</label>
                    <div class="col-md-8">
                        <select class="form-control" value="@selectedBrandId" @onchange="BrandSelectionChanged">
                            @foreach (var brand in brands)
                            {
                                <option value="@brand.Id">@brand.Brand</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-4">Type</label>
                    <div class="col-md-8">
                        <select class="form-control" value="@selectedTypeId" @onchange="TypeSelectionChanged">
                            @foreach (var type in types)
                            {
                                <option value="@type.Id">@type.Type</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-4">Price</label>
                    <div class="col-md-8">
                        <InputNumber id="Price" class="form-control" @bind-Value="catalogItem.Price" />
                        @if (hasSubmitted && (catalogItem.Price < 0 || catalogItem.Price > 1000000))
                        {
                            <span class="text-danger">The Price must be a positive number with maximum two decimals between 0 and 1 million.</span>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-4">Picture name</label>
                    <div class="col-md-8">
                        <InputText id="PictureFileName" class="form-control" @bind-Value="catalogItem.PictureFileName" readonly title="Not allowed for edition" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-4">Stock</label>
                    <div class="col-md-8">
                        <InputNumber id="Stock" class="form-control" @bind-Value="catalogItem.AvailableStock" />
                        @if (hasSubmitted && (catalogItem.AvailableStock < 0 || catalogItem.AvailableStock > 10000000))
                        {
                            <span class="text-danger">The field Stock must be between 0 and 10 million.</span>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-4">Restock</label>
                    <div class="col-md-8">
                        <InputNumber id="Restock" class="form-control" @bind-Value="catalogItem.RestockThreshold" />
                        @if (hasSubmitted && (catalogItem.RestockThreshold < 0 || catalogItem.RestockThreshold > 10000000))
                        {
                            <span class="text-danger">The field Restock must be between 0 and 10 million.</span>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-4">Max stock</label>
                    <div class="col-md-8">
                        <InputNumber id="Maxstock" class="form-control" @bind-Value="catalogItem.MaxStockThreshold" />
                        @if (hasSubmitted && (catalogItem.MaxStockThreshold < 0 || catalogItem.MaxStockThreshold > 10000000))
                        {
                            <span class="text-danger">The field Max stock must be between 0 and 10 million.</span>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-12 text-right esh-button-actions">
                        <NavLink href="/" class="btn esh-button esh-button-secondary">[ Cancel ]</NavLink>
                        <button type="submit" class="btn esh-button esh-button-primary">[ Save ]</button>
                    </div>
                </div>

            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private CatalogItem product = new CatalogItem();
    private CatalogItem catalogItem = new CatalogItem();
    private IEnumerable<CatalogBrand> brands = new List<CatalogBrand>();
    private IEnumerable<CatalogType> types = new List<CatalogType>();
    private int selectedBrandId;
    private int selectedTypeId;
    private bool hasSubmitted = false;

    protected override void OnInitialized()
    {
        Logger.LogInformation($"Now loading... /Catalog/Edit.aspx?id={Id}");

        product = CatalogService.FindCatalogItem(Id);

        brands = CatalogService.GetCatalogBrands();
        types = CatalogService.GetCatalogTypes();

        selectedBrandId = product.CatalogBrandId;
        selectedTypeId = product.CatalogTypeId;

        catalogItem = new CatalogItem
        {
            Id = product.Id,
            Name = product.Name,
            Description = product.Description,
            CatalogBrandId = product.CatalogBrandId,
            CatalogTypeId = product.CatalogTypeId,
            Price = product.Price,
            PictureFileName = product.PictureFileName,
            AvailableStock = product.AvailableStock,
            RestockThreshold = product.RestockThreshold,
            MaxStockThreshold = product.MaxStockThreshold
        };
    }

    private void BrandSelectionChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int brandId))
        {
            selectedBrandId = brandId;
            catalogItem.CatalogBrandId = brandId;
        }
    }

    private void TypeSelectionChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int typeId))
        {
            selectedTypeId = typeId;
            catalogItem.CatalogTypeId = typeId;
        }
    }

    public IEnumerable<CatalogBrand> GetBrands()
    {
        return CatalogService.GetCatalogBrands();
    }

    public IEnumerable<CatalogType> GetTypes()
    {
        return CatalogService.GetCatalogTypes();
    }

    private void Save_Click()
    {
        hasSubmitted = true;

        var isValid = !string.IsNullOrWhiteSpace(catalogItem.Name)
            && catalogItem.Price >= 0 && catalogItem.Price <= 1000000
            && catalogItem.AvailableStock >= 0 && catalogItem.AvailableStock <= 10000000
            && catalogItem.RestockThreshold >= 0 && catalogItem.RestockThreshold <= 10000000
            && catalogItem.MaxStockThreshold >= 0 && catalogItem.MaxStockThreshold <= 10000000;

        if (isValid)
        {
            var updatedItem = new CatalogItem
            {
                Id = Id,
                Name = catalogItem.Name,
                Description = catalogItem.Description,
                CatalogBrandId = selectedBrandId,
                CatalogTypeId = selectedTypeId,
                Price = catalogItem.Price,
                PictureFileName = catalogItem.PictureFileName,
                AvailableStock = catalogItem.AvailableStock,
                RestockThreshold = catalogItem.RestockThreshold,
                MaxStockThreshold = catalogItem.MaxStockThreshold
            };

            CatalogService.UpdateCatalogItem(updatedItem);

            NavigationManager.NavigateTo("/");
        }
    }
}